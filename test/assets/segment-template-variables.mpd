<?xml version="1.0" encoding="UTF-8"?>
<MPD xmlns="urn:mpeg:dash:schema:mpd:2011" type="static" mediaPresentationDuration="PT6S" minBufferTime="PT1.5S">
  <Period>
    <AdaptationSet mimeType="video/mp4" contentType="video">
      <Representation id="video-main" bandwidth="1200000" width="1280" height="720">
        <BaseURL>https://example.com/root/</BaseURL>
        <SegmentTemplate
          timescale="10"
          duration="20"
          startNumber="10"
          initialization="init-$$-$RepresentationID$-$Bandwidth$.mp4"
          media="chunk-$$-$RepresentationID$-$Bandwidth$-$Number%03d$-$Time$.m4s" />
      </Representation>
    </AdaptationSet>
  </Period>
</MPD>
