<?xml version="1.0" encoding="UTF-8"?>
<MPD xmlns="urn:mpeg:dash:schema:mpd:2011" type="static" mediaPresentationDuration="PT6S" minBufferTime="PT2S">
  <Period duration="PT6S">
    <AdaptationSet mimeType="video/mp4" segmentAlignment="true">
      <Representation id="repeat-video" bandwidth="800000" codecs="avc1.420015" width="640" height="360">
        <BaseURL>https://example.com/repeat/</BaseURL>
        <SegmentTemplate initialization="init.mp4" media="segment-$Time$.m4s" timescale="1" startNumber="1">
          <SegmentTimeline>
            <S d="2" r="-1"/>
          </SegmentTimeline>
        </SegmentTemplate>
      </Representation>
    </AdaptationSet>
  </Period>
</MPD>
