{
  "compilerOptions": {
    "target": "esnext",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "strict": true,
    "lib": ["ESNext", "DOM"],
    "types": ["node"],
    "forceConsistentCasingInFileNames": true,
    "noImplicitOverride": true,
    "noUncheckedSideEffectImports": true,
    "preserveWatchOutput": true
  },
  "include": ["*.ts", "lib/**/*.ts"]
}
