{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "singleQuote": true,
  "trailingComma": "all",
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "sortPackageJson": false,
  "ignorePatterns": ["README.md", "dist", "node_modules", "package.json", "package-lock.json"]
}
